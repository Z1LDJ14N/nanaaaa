<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Untuk Nanaa 💌</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Dancing+Script:wght@700&display=swap');

        body {
            margin: 0;
            background: #ffebee;
            font-family: 'Poppins', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        #halaman1, #halaman2 {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            text-align: center;
            position: absolute;
        }

        #halaman2 { display: none; padding: 20px; box-sizing: border-box; }

        /* Halaman 1 */
        .amplop {
            font-size: 100px;
            cursor: pointer;
            transition: 0.3s;
            filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));
            animation: float 2s infinite ease-in-out;
        }
        .teks-pencet {
            margin-top: 15px;
            font-weight: 600;
            color: #d81b60;
            background: white;
            padding: 8px 25px;
            border-radius: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        /* Halaman 2 */
        .foto-container {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }
        .foto-container img {
            width: 130px;
            height: 170px;
            object-fit: cover;
            border-radius: 15px;
            border: 4px solid #fff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .ucapan {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            color: #880e4f;
            line-height: 1.6;
            background: rgba(255,255,255,0.7);
            padding: 20px;
            border-radius: 20px;
            max-width: 350px;
            backdrop-filter: blur(5px);
        }

        .bold-text {
            font-family: 'Dancing Script', cursive;
            font-size: 26px;
            display: block;
            margin-bottom: 10px;
        }

        /* Animasi */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }
        .fade-in { animation: fadeIn 1.2s forwards; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

    <div id="halaman1">
        <div class="amplop" onclick="bukaSurat()">💌</div>
        <div class="teks-pencet" onclick="bukaSurat()">pencet</div>
    </div>

    <div id="halaman2">
        <div class="foto-container">
            <img src="https://autoresbot.com/tmp_files/2f5ab5c7-4455-464d-b510-1625727e52a1.jpg">
            <img src="https://autoresbot.com/tmp_files/cb09af4b-c457-4e4f-8a9d-17edc254a533.jpg">
        </div>
        
        <div class="ucapan">
            <span class="bold-text">NANAA MAU NGGA JADI PACARKU?</span>
            AKU GATAU KOK BISA TERPIKAT KALI AKU SAMA HATI KAMU NANAA, I LOVE YOU ❤️
        </div>

        <audio id="musikBg" loop>
            <source src="https://files.catbox.moe/978w1d.mp3" type="audio/mpeg">
        </audio>
    </div>

    <script>
        function bukaSurat() {
            document.getElementById('halaman1').style.display = 'none';
            var h2 = document.getElementById('halaman2');
            h2.style.display = 'flex';
            h2.classList.add('fade-in');
            
            // Putar musik saat diklik
            var audio = document.getElementById('musikBg');
            audio.play().catch(e => console.log("Gagal putar:", e));
        }
    </script>
</body>
</html>
